# Tessera Environment Configuration
# Copy to .env and fill in values

# --- General ---
TESSERA_DEBUG=false
TESSERA_LOG_LEVEL=INFO

# --- Database ---
TESSERA_POSTGRES_DSN=postgresql://tessera:tessera@localhost:5432/tessera

# --- Redis ---
TESSERA_REDIS_URL=redis://localhost:6379/0

# --- Exchange API Keys (Binance) ---
TESSERA_BINANCE_API_KEY=
TESSERA_BINANCE_API_SECRET=
TESSERA_BINANCE_TESTNET=true

# --- Exchange API Keys (Bybit) ---
TESSERA_BYBIT_API_KEY=
TESSERA_BYBIT_API_SECRET=
TESSERA_BYBIT_TESTNET=true

# --- Data Providers ---
TESSERA_TARDIS_API_KEY=

# --- Observability ---
TESSERA_SENTRY_DSN=
TESSERA_PROMETHEUS_PORT=9090

# --- Risk Controls ---
TESSERA_MAX_POSITION_USD=10000
TESSERA_MAX_DRAWDOWN_PCT=0.05
TESSERA_KILL_SWITCH=false
